# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# An RPC endpoint for the Sepolia testnet (Alchemy, Infura, or your own node).
SEPOLIA_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY"

# Etherscan API key, used to verify the contract source after deploying.
ETHERSCAN_API_KEY="YOUR_ETHERSCAN_KEY"

# NOTE: we do NOT store a raw private key here. Import your deployer key once into
# Foundry's encrypted keystore instead:
#   cast wallet import deployer --interactive
# then deploy with `--account deployer`. See README for details.
